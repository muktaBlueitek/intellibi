# IntelliBI Environment Variables
# Copy to .env and update values

# Application
ENVIRONMENT=development

# Security - REQUIRED for production
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=intellibi
POSTGRES_PASSWORD=intellibi
POSTGRES_DB=intellibi

# Redis (optional - caching disabled if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# AI/Chatbot (required for natural language queries)
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_BASE_URL=

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000
