# IntelliBI Backend Environment Variables
# Copy to .env in backend/ and update values

ENVIRONMENT=development
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=intellibi
POSTGRES_PASSWORD=intellibi
POSTGRES_DB=intellibi

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_BASE_URL=
